# for both BMP & SPO2
from machine import Pin, I2C
import time

# -------------------------------
# I2C SETUP
# -------------------------------
i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=100000)
ADDR = 0x57

# -------------------------------
# INIT MAX30102
# -------------------------------
i2c.writeto_mem(ADDR, 0x09, b'\x40')  # reset
time.sleep(1)

i2c.writeto_mem(ADDR, 0x09, b'\x03')  # SPO2 mode
i2c.writeto_mem(ADDR, 0x0A, b'\x27')  # 100Hz
i2c.writeto_mem(ADDR, 0x0C, b'\x24')  # LED power
i2c.writeto_mem(ADDR, 0x0D, b'\x24')

# -------------------------------
# READ SENSOR
# -------------------------------
def read_fifo():
    data = i2c.readfrom_mem(ADDR, 0x07, 6)
    red = (data[0]<<16 | data[1]<<8 | data[2]) & 0x3FFFF
    ir  = (data[3]<<16 | data[4]<<8 | data[5]) & 0x3FFFF
    return red, ir

# -------------------------------
# VARIABLES
# -------------------------------
alpha = 0.95
avg_red = 0
avg_ir = 0

red_ac = []
ir_ac = []
BUFFER_SIZE = 50

prev_signal = 0
last_beat = 0

bpm_list = []
bpm = 0

finger_count = 0
NO_FINGER_THRESHOLD = 8000   # tuned
STABLE_COUNT = 8

# -------------------------------
# LOOP
# -------------------------------
while True:
    red, ir = read_fifo()

    # -------------------------------
    # FINGER DETECTION (DC level)
    # -------------------------------
    if ir > NO_FINGER_THRESHOLD:
        finger_count += 1
    else:
        finger_count = 0

    finger_present = finger_count > STABLE_COUNT

    # -------------------------------
    # DC REMOVAL
    # -------------------------------
    avg_red = alpha * avg_red + (1 - alpha) * red
    avg_ir  = alpha * avg_ir  + (1 - alpha) * ir

    ac_red = red - avg_red
    ac_ir  = ir - avg_ir

    # -------------------------------
    # STORE BUFFER
    # -------------------------------
    red_ac.append(ac_red)
    ir_ac.append(ac_ir)

    if len(red_ac) > BUFFER_SIZE:
        red_ac.pop(0)
        ir_ac.pop(0)

    # -------------------------------
    # ❤️ BPM CALCULATION
    # -------------------------------
    if finger_present:
        if ac_red > 120 and prev_signal <= 120:   # peak detect

            now = time.ticks_ms()

            if last_beat != 0:
                new_bpm = 60000 / time.ticks_diff(now, last_beat)

                # valid human range
                if 45 < new_bpm < 180:
                    bpm_list.append(new_bpm)

                    if len(bpm_list) > 5:
                        bpm_list.pop(0)

                    bpm = int(sum(bpm_list) / len(bpm_list))

            last_beat = now

    prev_signal = ac_red

    # -------------------------------
    # 🫁 SpO2 CALCULATION
    # -------------------------------
    spo2 = None

    if finger_present and len(red_ac) == BUFFER_SIZE:

        # RMS AC
        ac_red_val = (sum([x*x for x in red_ac]) / BUFFER_SIZE) ** 0.5
        ac_ir_val  = (sum([x*x for x in ir_ac]) / BUFFER_SIZE) ** 0.5

        dc_red = avg_red
        dc_ir  = avg_ir

        if dc_ir > 0 and ac_ir_val > 0:
            R = (ac_red_val / dc_red) / (ac_ir_val / dc_ir)

            calc_spo2 = 110 - 25 * R

            if 85 < calc_spo2 < 100:
                spo2 = int(calc_spo2)

    # -------------------------------
    # OUTPUT (FINAL CLEAN LOGIC)
    # -------------------------------
    if finger_present:

        if bpm > 0 and spo2 is not None:
            print("❤️ BPM:", bpm, "| 🫁 SpO2:", spo2, "%")

        else:
            print("⏳ Reading...")

    else:
        print("❌ No finger")

        # RESET EVERYTHING
        red_ac.clear()
        ir_ac.clear()
        bpm_list.clear()
        bpm = 0
        last_beat = 0

        time.sleep(0.1)
        continue

    time.sleep(0.05)