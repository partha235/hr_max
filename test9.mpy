# ==========================================
# ESP32 MAX30102 (BPM + SpO2) + DS18B20 Temperature
# Combined & Improved Version
# ==========================================

from machine import Pin, I2C
import onewire, ds18x20
import time

# -------------------------------
# MAX30102 Setup
# -------------------------------
i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=400000)
ADDR = 0x57

def init_max30102():
    i2c.writeto_mem(ADDR, 0x09, b'\x40')  # Reset
    time.sleep(0.1)
    i2c.writeto_mem(ADDR, 0x09, b'\x03')   # Mode: SpO2 + HR
    i2c.writeto_mem(ADDR, 0x0A, b'\x47')   # FIFO: avg 4 samples, rollover enabled
    i2c.writeto_mem(ADDR, 0x0C, b'\x27')   # SpO2 config: 100Hz, 411µs pulse
    i2c.writeto_mem(ADDR, 0x0D, b'\x24')   # Red LED current
    i2c.writeto_mem(ADDR, 0x0E, b'\x24')   # IR LED current

init_max30102()

def read_fifo():
    data = i2c.readfrom_mem(ADDR, 0x07, 6)
    red = (data[0] << 16 | data[1] << 8 | data[2]) & 0x3FFFF
    ir  = (data[3] << 16 | data[4] << 8 | data[5]) & 0x3FFFF
    return red, ir

# -------------------------------
# DS18B20 Setup
# -------------------------------
ds_pin = Pin(4)
ds_sensor = ds18x20.DS18X20(onewire.OneWire(ds_pin))
roms = ds_sensor.scan()
print("DS18B20 found:", roms)

# -------------------------------
# Variables
# -------------------------------
alpha = 0.95
avg_red = 0.0
avg_ir = 0.0

red_ac = []
ir_ac = []
BUFFER_SIZE = 80          # Good balance for SpO2 accuracy

prev_signal = 0
last_beat = 0
bpm_list = []
bpm = None

finger_count = 0
NO_FINGER_THRESHOLD = 30000   # Adjust based on your sensor (typical good values: 20000-60000)
STABLE_COUNT = 8

spo2 = None
temperature = None
temp_convert_start = 0

print("Place finger on sensor...")

# -------------------------------
# Main Loop
# -------------------------------
while True:
    red, ir = read_fifo()

    # Finger detection (IR is more reliable)
    if ir > NO_FINGER_THRESHOLD:
        finger_count = min(finger_count + 1, STABLE_COUNT + 5)
    else:
        finger_count = max(finger_count - 2, 0)

    finger_present = finger_count > STABLE_COUNT

    # DC removal (IIR low-pass filter)
    avg_red = alpha * avg_red + (1 - alpha) * red
    avg_ir  = alpha * avg_ir  + (1 - alpha) * ir

    ac_red = red - avg_red
    ac_ir  = ir  - avg_ir

    red_ac.append(ac_red)
    ir_ac.append(ac_ir)
    if len(red_ac) > BUFFER_SIZE:
        red_ac.pop(0)
        ir_ac.pop(0)

    # === BPM Calculation ===
    if finger_present:
        if ac_red > 180 and prev_signal <= 180:   # Rising edge threshold
            now = time.ticks_ms()
            if last_beat != 0:
                interval = time.ticks_diff(now, last_beat)
                if 300 < interval < 1500:          # 40 ~ 200 BPM
                    new_bpm = 60000 / interval
                    bpm_list.append(new_bpm)
                    if len(bpm_list) > 10:
                        bpm_list.pop(0)
                    bpm = int(sum(bpm_list) / len(bpm_list))
            last_beat = now
    else:
        bpm = None
        bpm_list.clear()

    prev_signal = ac_red

    # === SpO2 Calculation ===
    if finger_present and len(red_ac) == BUFFER_SIZE:
        ac_red_rms = (sum(x*x for x in red_ac) / BUFFER_SIZE) ** 0.5
        ac_ir_rms  = (sum(x*x for x in ir_ac)  / BUFFER_SIZE) ** 0.5

        if avg_ir > 10 and ac_ir_rms > 5:
            R = (ac_red_rms / avg_red) / (ac_ir_rms / avg_ir)
            calc_spo2 = 110 - 25 * R
            if 85 < calc_spo2 < 100:
                spo2 = int(calc_spo2)
            else:
                spo2 = None
        else:
            spo2 = None
    else:
        spo2 = None

    # === Temperature (non-blocking) ===
    now_ms = time.ticks_ms()
    if now_ms - temp_convert_start > 2000:
        ds_sensor.convert_temp()
        temp_convert_start = now_ms
    elif now_ms - temp_convert_start > 750 and roms:
        temperature = round(ds_sensor.read_temp(roms[0]), 1)

    # === Output ===
    if finger_present:
        print(f"❤️ BPM: {bpm if bpm else '--'}   |   🫁 SpO2: {spo2 if spo2 else '--'}%   |   🌡️ Temp: {temperature if temperature else '--'}°C")
    else:
        print("❌ No finger detected")

    time.sleep_ms(40)   # ~25 Hz sampling - good compromise