from machine import Pin, I2C
import time
import onewire, ds18x20

# -------------------------------
# I2C (MAX30102)
# -------------------------------
i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=100000)
ADDR = 0x57

# -------------------------------
# MAX30102 INIT
# -------------------------------
i2c.writeto_mem(ADDR, 0x09, b'\x40')
time.sleep(1)

i2c.writeto_mem(ADDR, 0x09, b'\x03')
i2c.writeto_mem(ADDR, 0x0A, b'\x27')
i2c.writeto_mem(ADDR, 0x0C, b'\x24')
i2c.writeto_mem(ADDR, 0x0D, b'\x24')

def read_fifo():
    data = i2c.readfrom_mem(ADDR, 0x07, 6)
    red = (data[0]<<16 | data[1]<<8 | data[2]) & 0x3FFFF
    ir  = (data[3]<<16 | data[4]<<8 | data[5]) & 0x3FFFF
    return red, ir

# -------------------------------
# DS18B20 TEMP SENSOR
# -------------------------------
ds_pin = Pin(4)
ds_sensor = ds18x20.DS18X20(onewire.OneWire(ds_pin))
roms = ds_sensor.scan()

print("Temp sensors:", roms)

# -------------------------------
# VARIABLES
# -------------------------------
alpha = 0.97
avg_red = 0
avg_ir = 0

red_ac = []
ir_ac = []
BUFFER_SIZE = 50

prev_signal = 0
last_beat = 0

bpm_list = []
bpm = 0

finger_count = 0
NO_FINGER_THRESHOLD = 8000
STABLE_COUNT = 8

temperature = None
last_temp_time = 0

# -------------------------------
# LOOP
# -------------------------------
while True:
    red, ir = read_fifo()

    # -------------------------------
    # FINGER DETECTION
    # -------------------------------
    if ir > NO_FINGER_THRESHOLD:
        finger_count += 1
    else:
        finger_count = 0

    finger_present = finger_count > STABLE_COUNT

    # -------------------------------
    # DC REMOVAL
    # -------------------------------
    avg_red = alpha * avg_red + (1 - alpha) * red
    avg_ir  = alpha * avg_ir  + (1 - alpha) * ir

    ac_red = red - avg_red
    ac_ir  = ir - avg_ir

    # -------------------------------
    # BUFFER
    # -------------------------------
    red_ac.append(ac_red)
    ir_ac.append(ac_ir)

    if len(red_ac) > BUFFER_SIZE:
        red_ac.pop(0)
        ir_ac.pop(0)

    # -------------------------------
    # ❤️ BPM
    # -------------------------------
    if finger_present:
        if ac_red > 150 and prev_signal <= 150:

            now = time.ticks_ms()

            if last_beat != 0:
                new_bpm = 60000 / time.ticks_diff(now, last_beat)

                if 45 < new_bpm < 180:
                    bpm_list.append(new_bpm)

                    if len(bpm_list) > 5:
                        bpm_list.pop(0)

                    bpm = int(sum(bpm_list) / len(bpm_list))

            last_beat = now

    prev_signal = ac_red

    # -------------------------------
    # 🫁 SpO2
    # -------------------------------
    spo2 = None

    if finger_present and len(red_ac) == BUFFER_SIZE:

        ac_red_val = (sum([x*x for x in red_ac]) / BUFFER_SIZE) ** 0.5
        ac_ir_val  = (sum([x*x for x in ir_ac]) / BUFFER_SIZE) ** 0.5

        dc_red = avg_red
        dc_ir  = avg_ir

        if dc_ir > 0 and ac_ir_val > 0:
            R = (ac_red_val / dc_red) / (ac_ir_val / dc_ir)
            calc_spo2 = 110 - 25 * R

            if 85 < calc_spo2 < 100:
                spo2 = int(calc_spo2)

    # -------------------------------
    # 🌡️ TEMPERATURE (every 2 sec)
    # -------------------------------
    if time.ticks_diff(time.ticks_ms(), last_temp_time) > 2000:
        ds_sensor.convert_temp()
        time.sleep_ms(750)

        for rom in roms:
            temperature = ds_sensor.read_temp(rom)

        last_temp_time = time.ticks_ms()

    # -------------------------------
    # OUTPUT
    # -------------------------------
    if finger_present:

        if bpm > 0 and spo2 is not None:
            print("❤️ BPM:", bpm,
                  "| 🫁 SpO2:", spo2, "%",
                  "| 🌡️ Temp:", temperature if temperature else "--", "°C")
        else:
            print("⏳ Reading...")

    else:
        print("❌ No finger")

        # RESET
        red_ac.clear()
        ir_ac.clear()
        bpm_list.clear()
        bpm = 0
        last_beat = 0

    time.sleep(0.05)