from machine import Pin, I2C
import time

i2c = I2C(0, scl=Pin(22), sda=Pin(21), freq=100000)
ADDR = 0x57

# --- INIT MAX30102 ---
i2c.writeto_mem(ADDR, 0x09, b'\x40')
time.sleep(1)

i2c.writeto_mem(ADDR, 0x09, b'\x03')
i2c.writeto_mem(ADDR, 0x0A, b'\x27')
i2c.writeto_mem(ADDR, 0x0C, b'\x24')
i2c.writeto_mem(ADDR, 0x0D, b'\x24')
i2c.writeto_mem(ADDR, 0x0C, b'\x3F')  # stronger LED

def read_fifo():
    data = i2c.readfrom_mem(ADDR, 0x07, 6)
    red = (data[0] << 16 | data[1] << 8 | data[2]) & 0x3FFFF
    return red

# --- FILTER ---
avg = 0
alpha = 0.95

prev = 0
last_beat = 0

while True:
    red = read_fifo()

    avg = alpha * avg + (1 - alpha) * red
    signal = red - avg

    # Finger detection
    if red < 2000:
        print("❌ No finger")
        time.sleep(0.1)
        continue

    print("🟢 Finger detected")

    # Peak detection
    if signal > 120 and prev <= 120:
        now = time.ticks_ms()

        if last_beat != 0:
            diff = time.ticks_diff(now, last_beat)

            if diff > 300:  # debounce
                bpm = 60000 / diff
                print("❤️ BPM:", int(bpm))

        last_beat = now

    prev = signal
    print("Signal:", int(signal))

    time.sleep(0.05)